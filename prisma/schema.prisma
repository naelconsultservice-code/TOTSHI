generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum Language {
  fr
  en
}

enum NeedType {
  DEVELOPPEMENT
  MARKETING
  CONSULTANCE
  INDETERMINE
}

enum ProjectType {
  SITE_WEB
  APP_WEB
  APP_MOBILE
  SYSTEME_GESTION
  ECOMMERCE
  MARKETPLACE
  ERP_CRM
  FINTECH
  IA_AUTOMATISATION
  STRATEGIE_DIGITALE
  SEO_REFERENCEMENT
  PUBLICITE_EN_LIGNE
  RESEAUX_SOCIAUX
  CREATION_CONTENU
  EMAIL_MARKETING
  BRANDING_IDENTITE
  MARKETING_COMPLET
  AUDIT_DIGITAL
  STRATEGIE_TRANSFORMATION
  CHOIX_TECHNOLOGIQUES
  ACCOMPAGNEMENT_PROJET
  FORMATION_EQUIPES
  CONSEIL_CROISSANCE
  PRESENCE_EN_LIGNE
  AUTOMATISER_PROCESSUS
  DEVELOPPER_ACTIVITE
  RESOUDRE_PROBLEME
  AUTRE
}

enum SubmissionStatus {
  NOUVEAU
  EN_COURS
  BRIEF_ENVOYE
  EN_ATTENTE_CLIENT
  PROPOSITION_ENVOYEE
  CONFIRME
  NON_QUALIFIE
  ARCHIVE
}

enum DocumentType {
  BRIEF
  DRAFT_CDC
  PROPOSITION
}

enum GenerationStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model Prospect {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  firstName   String       @map("first_name")
  lastName    String       @map("last_name")
  email       String       @unique
  phone       String?
  company     String?
  country     String
  sector      String
  language    Language     @default(fr)
  submissions Submission[]

  @@map("prospects")
}

model Submission {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  prospectId        String           @map("prospect_id") @db.Uuid
  prospect          Prospect         @relation(fields: [prospectId], references: [id])

  needType          NeedType         @default(DEVELOPPEMENT)
  projectType       ProjectType      @map("project_type")
  description       String
  targetUsers       Json             @map("target_users")
  features          Json
  constraints       Json
  rawResponses      Json             @default("{}") @map("raw_responses")
  status            SubmissionStatus @default(NOUVEAU)
  completenessScore Int?             @map("completeness_score")
  honeypotFlagged   Boolean          @default(false) @map("honeypot_flagged")
  ipAddress         String?          @map("ip_address")
  language          Language         @default(fr)
  gdprConsent       Boolean          @default(true) @map("gdpr_consent")
  gdprConsentAt     DateTime?        @default(now()) @map("gdpr_consent_at")

  documents         GeneratedDocument[]
  statusHistory     StatusHistory[]
  notes             InternalNote[]

  @@map("submissions")
}

model GeneratedDocument {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at")

  submissionId     String           @map("submission_id") @db.Uuid
  submission       Submission       @relation(fields: [submissionId], references: [id])

  type             DocumentType
  content          String
  language         Language
  generationStatus GenerationStatus @default(PENDING) @map("generation_status")
  errorMessage     String?          @map("error_message")
  version          Int              @default(1)

  @@map("generated_documents")
}

model StatusHistory {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at")

  submissionId String            @map("submission_id") @db.Uuid
  submission   Submission        @relation(fields: [submissionId], references: [id])

  fromStatus   SubmissionStatus? @map("old_status")
  toStatus     SubmissionStatus  @map("new_status")
  changedBy    String            @map("changed_by")

  @@map("status_history")
}

model InternalNote {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")

  submissionId String     @map("submission_id") @db.Uuid
  submission   Submission @relation(fields: [submissionId], references: [id])

  content      String

  @@map("internal_notes")
}

model Project {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  slug           String   @unique
  titleFr        String   @map("title_fr")
  titleEn        String   @map("title_en")
  category       String
  descriptionFr  String   @map("description_fr")
  descriptionEn  String   @map("description_en")
  problemFr      String   @map("problem_fr")
  problemEn      String   @map("problem_en")
  resultFr       String   @map("result_fr")
  resultEn       String   @map("result_en")
  technologies   String[]
  coverImageUrl  String?  @map("cover_image_url")
  isPublished    Boolean  @default(false) @map("is_published")
  displayOrder   Int      @default(0) @map("display_order")

  @@map("projects")
}

model AdminUser {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  email          String    @unique
  passwordHash   String    @map("password_hash")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")

  @@map("admin_users")
}
model Article {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  slug           String    @unique
  titleFr        String    @map("title_fr")
  titleEn        String    @map("title_en")
  excerptFr      String    @map("excerpt_fr")
  excerptEn      String    @map("excerpt_en")
  contentFr      String    @map("content_fr")
  contentEn      String    @map("content_en")
  category       String
  coverImageUrl  String?   @map("cover_image_url")
  author         String    @default("TOTSHI")
  readingMinutes  Int      @default(5) @map("reading_minutes")
  isPublished    Boolean   @default(false) @map("is_published")
  publishedAt    DateTime? @map("published_at")

  @@map("articles")
}

model Testimonial {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  clientName      String   @map("client_name") @db.VarChar
  clientRole      String?  @map("client_role") @db.VarChar
  clientCompany   String?  @map("client_company") @db.VarChar
  clientAvatarUrl String?  @map("client_avatar_url") @db.VarChar
  contentFr       String   @map("content_fr")
  contentEn       String   @map("content_en")
  rating          Int      @default(5)
  projectSlug     String?  @map("project_slug") @db.VarChar
  isPublished     Boolean  @default(false) @map("is_published")
  displayOrder    Int      @default(0) @map("display_order")

  @@map("testimonials")
}