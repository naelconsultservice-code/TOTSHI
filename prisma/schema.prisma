generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

enum Language {
  fr
  en
}

enum NeedType {
  DEVELOPPEMENT
  MARKETING
  CONSULTANCE
  INDETERMINE
}

enum ProjectType {
  // Développement
  SITE_WEB
  APP_WEB
  APP_MOBILE
  SYSTEME_GESTION
  ECOMMERCE
  MARKETPLACE
  ERP_CRM
  FINTECH
  IA_AUTOMATISATION
  // Marketing
  STRATEGIE_DIGITALE
  SEO_REFERENCEMENT
  PUBLICITE_EN_LIGNE
  RESEAUX_SOCIAUX
  CREATION_CONTENU
  EMAIL_MARKETING
  BRANDING_IDENTITE
  MARKETING_COMPLET
  // Consultance
  AUDIT_DIGITAL
  STRATEGIE_TRANSFORMATION
  CHOIX_TECHNOLOGIQUES
  ACCOMPAGNEMENT_PROJET
  FORMATION_EQUIPES
  CONSEIL_CROISSANCE
  // Indéterminé
  PRESENCE_EN_LIGNE
  AUTOMATISER_PROCESSUS
  DEVELOPPER_ACTIVITE
  RESOUDRE_PROBLEME
  AUTRE
}

enum SubmissionStatus {
  NOUVEAU
  EN_COURS
  BRIEF_ENVOYE
  EN_ATTENTE_CLIENT
  PROPOSITION_ENVOYEE
  CONFIRME
  NON_QUALIFIE
  ARCHIVE
}

enum DocumentType {
  BRIEF
  DRAFT_CDC
  PROPOSITION
}

enum GenerationStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────

model Prospect {
  id          String       @id @default(cuid())
  email       String       @unique
  firstName   String
  lastName    String
  phone       String?
  company     String?
  country     String
  sector      String
  language    Language     @default(fr)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions Submission[]

  @@map("prospects")
}

model Submission {
  id                String           @id @default(cuid())
  needType          NeedType         @default(DEVELOPPEMENT)
  projectType       ProjectType
  description       String
  targetUsers       Json
  features          Json
  constraints       Json
  completenessScore Int?
  status            SubmissionStatus @default(NOUVEAU)
  language          Language         @default(fr)
  honeypot          String?
  gdprConsent       Boolean          @default(false)
  gdprConsentAt     DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  prospect          Prospect         @relation(fields: [prospectId], references: [id])
  prospectId        String

  documents         GeneratedDocument[]
  statusHistory     StatusHistory[]
  notes             InternalNote[]

  @@map("submissions")
}

model GeneratedDocument {
  id               String           @id @default(cuid())
  type             DocumentType
  content          String
  language         Language
  generationStatus GenerationStatus @default(PENDING)
  errorMessage     String?
  version          Int              @default(1)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  submission       Submission       @relation(fields: [submissionId], references: [id])
  submissionId     String

  @@map("generated_documents")
}

model StatusHistory {
  id           String           @id @default(cuid())
  fromStatus   SubmissionStatus?
  toStatus     SubmissionStatus
  changedBy    String
  note         String?
  createdAt    DateTime         @default(now())

  submission   Submission       @relation(fields: [submissionId], references: [id])
  submissionId String

  @@map("status_history")
}

model InternalNote {
  id           String     @id @default(cuid())
  content      String
  author       String
  createdAt    DateTime   @default(now())

  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId String

  @@map("internal_notes")
}

model Project {
  id             String   @id @default(cuid())
  slug           String   @unique
  titleFr        String
  titleEn        String
  descriptionFr  String
  descriptionEn  String
  problemFr      String
  problemEn      String
  resultFr       String
  resultEn       String
  category       String
  technologies   String[]
  coverImageUrl  String?
  isPublished    Boolean  @default(false)
  displayOrder   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("projects")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  failedLogins Int      @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}